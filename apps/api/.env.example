# Server
PORT=4000
WEB_URL=http://localhost:3000
SESSION_SECRET=replace-me

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/whitelist

# Discord OAuth
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=http://localhost:4000/auth/discord/callback

# Discord webhook
DISCORD_WEBHOOK_URL=

# Discord bot (recommended, for auto tickets + Accept/Reject buttons inside Discord)
DISCORD_BOT_TOKEN=

# Main/community server ticket
DISCORD_MAIN_GUILD_ID=
DISCORD_MAIN_CATEGORY_ID=
DISCORD_MAIN_STAFF_ROLE_IDS=

# Staff server ticket (private)
DISCORD_STAFF_GUILD_ID=
DISCORD_STAFF_CATEGORY_ID=
DISCORD_STAFF_ROLE_IDS_STAFF=

# Backwards compatible (single server setup)
DISCORD_GUILD_ID=
DISCORD_CATEGORY_ID=
DISCORD_STAFF_ROLE_IDS=

# Roles (assigned in the MAIN guild on decisions / minor self-declare)
DISCORD_MAIN_ROLE_APPROVED_ID=
DISCORD_MAIN_ROLE_REJECTED_ID=
DISCORD_MAIN_ROLE_MINOR_ID=
DISCORD_MAIN_ROLE_VAC_ID=

# Staff logs channel (in staff guild)
DISCORD_STAFF_LOG_CHANNEL_ID=
